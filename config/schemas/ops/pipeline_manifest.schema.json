{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow Pipeline Manifest",
  "description": "A pipeline composes multiple capabilities into a single executable flow. Pipelines can be built-in (shipped under /plugins/pipelines/) or user-created (saved under output/ops_platform/pipelines/). Both forms validate against this schema.",
  "type": "object",
  "required": ["pipeline_id", "name", "version", "steps", "created_by"],
  "properties": {
    "pipeline_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{2,63}$"
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "created_by": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "team": { "type": "string" }
      },
      "additionalProperties": false
    },
    "department": { "type": "string" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "input_mappings": {
      "type": "array",
      "description": "How pipeline-level inputs are routed to step inputs. Each mapping has source (pipeline_input or $.step_id.field) and target (step_id.input_name).",
      "items": { "$ref": "#/$defs/mapping" }
    },
    "output_mappings": {
      "type": "array",
      "description": "How step outputs are surfaced as pipeline outputs.",
      "items": { "$ref": "#/$defs/mapping" }
    },
    "execution_strategy": {
      "type": "string",
      "enum": ["sequential", "parallel_independent", "fan_out"],
      "default": "sequential"
    },
    "estimated_time_savings": {
      "type": "object",
      "properties": {
        "minutes_per_run": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "recommended_roles": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "shared_with": {
      "type": "array",
      "items": { "type": "string" },
      "description": "User/team identifiers. Empty = private to created_by."
    },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/io_field" },
      "description": "Pipeline-level inputs that callers must provide at launch."
    },
    "outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/io_field" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "step": {
      "type": "object",
      "required": ["step_id", "capability_id"],
      "properties": {
        "step_id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "name": { "type": "string" },
        "capability_id": { "type": "string", "description": "Plugin id to execute at this step." },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Step IDs that must complete before this step runs."
        },
        "input_bindings": {
          "type": "object",
          "description": "Maps this step's input names to either a literal value, '$pipeline.input_name', or '$step.<step_id>.<field>'.",
          "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
        },
        "on_failure": {
          "oneOf": [
            { "type": "string", "enum": ["abort", "skip", "retry_once"] },
            {
              "type": "object",
              "properties": {
                "retry": { "type": "integer", "minimum": 0, "maximum": 5 }
              },
              "required": ["retry"],
              "additionalProperties": false
            }
          ],
          "description": "abort | skip | retry_once | {retry: N}"
        },
        "when": {
          "description": "Optional condition. String form for truthy lookup ($pipeline.x / $step.s.field), or object form {equals:[a,b]} / {truthy:ref}.",
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "properties": {
                "equals": { "type": "array", "minItems": 2, "maxItems": 2 },
                "truthy": { "type": "string" }
              },
              "additionalProperties": false
            }
          ]
        },
        "required_status": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["succeeded"],
          "description": "Statuses considered acceptable to continue. Defaults to ['succeeded']."
        }
      },
      "additionalProperties": false
    },
    "mapping": {
      "type": "object",
      "required": ["source", "target"],
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string" }
      },
      "additionalProperties": false
    },
    "io_field": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "required": { "type": "boolean" },
        "default": {}
      },
      "additionalProperties": false
    }
  }
}

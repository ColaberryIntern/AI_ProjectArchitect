{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Session",
  "description": "Persisted session row. Created by auth.login(), looked up by session_id from the request header X-Session-Id (or the future cookie). One file per session under output/ops_platform/sessions/.",
  "type": "object",
  "required": ["session_id", "user_id", "issued_at", "expires_at", "auth_provider"],
  "properties": {
    "session_id": { "type": "string", "examples": ["b3a1-..."] },
    "user_id": { "type": "string" },
    "display_name": { "type": "string" },
    "email": { "type": "string" },
    "department": { "type": "string" },
    "roles": {
      "type": "array",
      "items": { "type": "string", "enum": ["admin", "operator", "reviewer", "builder", "viewer"] }
    },
    "workspace_ids": { "type": "array", "items": { "type": "string" } },
    "issued_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "auth_provider": {
      "type": "string",
      "enum": ["LOCAL_DEV", "HEADER_AUTH", "STATIC_TOKEN", "FUTURE_OIDC_PLACEHOLDER"]
    },
    "ip": { "type": "string" }
  },
  "additionalProperties": false
}
